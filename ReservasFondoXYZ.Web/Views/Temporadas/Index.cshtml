@model IEnumerable<ReservasFondoXYZ.Data.Models.Temporada>

@{
    ViewData["Title"] = "Temporadas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Temporadas</h1>
    <a asp-action="Create" class="btn btn-primary">Nueva Temporada</a>
</div>

<div class="table-responsive">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Tipo</th>
                <th>Inicio</th>
                <th>Fin</th>
                <th>Activa</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Nombre</td>
                    <td>@item.TipoTemporada?.Nombre</td>
                    <td>@item.FechaInicio.ToString("dd/MM/yyyy")</td>
                    <td>@item.FechaFin.ToString("dd/MM/yyyy")</td>
                    <td>@(item.Activo ? "Sí" : "No")</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Ver</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
