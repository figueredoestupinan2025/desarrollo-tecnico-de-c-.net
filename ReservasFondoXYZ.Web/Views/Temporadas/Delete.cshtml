@model ReservasFondoXYZ.Data.Models.Temporada

@{
    ViewData["Title"] = "Eliminar Temporada";
}

<h1>Eliminar Temporada</h1>
<div class="alert alert-warning">La temporada se desactivará para conservar histórico.</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <p><strong>@Model.Nombre</strong> (@Model.FechaInicio.ToString("dd/MM/yyyy") - @Model.FechaFin.ToString("dd/MM/yyyy"))</p>
    <button type="submit" class="btn btn-danger">Desactivar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
