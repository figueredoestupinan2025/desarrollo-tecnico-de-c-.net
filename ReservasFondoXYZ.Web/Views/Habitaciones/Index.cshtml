@model IEnumerable<ReservasFondoXYZ.Data.Models.Habitacion>

@{
    ViewData["Title"] = "Habitaciones";
}

<div class="container mt-4">
    <h1 class="text-center mb-4" style="color: #8B0000;">Habitaciones</h1>
    
    <div class="d-flex justify-content-end mb-3">
        <a asp-action="Create" class="btn btn-primary" style="background-color: #8B0000; border-color: #8B0000;">
            <i class="bi bi-plus-lg"></i> Nueva Habitación
        </a>
    </div>
    
    <div class="table-responsive">
        <table class="table table-hover">
            <thead style="background-color: #8B0000; color: white;">
                <tr>
                    <th>Número</th>
                    <th>Alojamiento</th>
                    <th>Sitio</th>
                    <th>Descripción</th>
                    <th>Capacidad</th>
                    <th>Estado</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var habitacion in Model)
                {
                    <tr>
                        <td>@habitacion.Numero</td>
                        <td>@habitacion.Alojamiento?.Nombre</td>
                        <td>@habitacion.Alojamiento?.Sitio?.Nombre</td>
                        <td>@habitacion.Descripcion</td>
                        <td>@habitacion.CapacidadMaxima personas</td>
                        <td>
                            @if (habitacion.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="btn-group">
                                <a asp-action="Details" asp-route-id="@habitacion.Id" class="btn btn-sm btn-info">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@habitacion.Id" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@habitacion.Id" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>