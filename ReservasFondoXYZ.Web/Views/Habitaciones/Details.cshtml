@model ReservasFondoXYZ.Data.Models.Habitacion

@{
    ViewData["Title"] = "Detalle de Habitación";
}

<div class="container mt-4">
    <h1 class="text-center mb-4" style="color: #8B0000;">Detalle de Habitación</h1>
    
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header" style="background-color: #8B0000; color: white;">
                    <h4>Habitación @Model.Numero</h4>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Alojamiento</dt>
                        <dd class="col-sm-8">@Model.Alojamiento?.Nombre</dd>

                        <dt class="col-sm-4">Sitio</dt>
                        <dd class="col-sm-8">@Model.Alojamiento?.Sitio?.Nombre</dd>

                        <dt class="col-sm-4">Número</dt>
                        <dd class="col-sm-8">@Model.Numero</dd>

                        <dt class="col-sm-4">Descripción</dt>
                        <dd class="col-sm-8">@Model.Descripcion</dd>

                        <dt class="col-sm-4">Capacidad Máxima</dt>
                        <dd class="col-sm-8">@Model.CapacidadMaxima personas</dd>

                        <dt class="col-sm-4">Estado</dt>
                        <dd class="col-sm-8">
                            @if (Model.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </dd>
                    </dl>
                </div>
                <div class="card-footer">
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Volver a la Lista
                        </a>
                        <div>
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Eliminar
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>