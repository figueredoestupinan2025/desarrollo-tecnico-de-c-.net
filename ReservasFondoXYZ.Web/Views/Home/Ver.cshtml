@{
    ViewData["Title"] = "Ver Detalle - FODUN";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Sedes Recreativas y Apartamentos</a></li>
                    <li class="breadcrumb-item active">Ver Detalle</li>
                </ol>
            </nav>
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-body">
                    <h4 class="card-title text-danger fw-bold mb-4">Detalle del Sitio</h4>
                    <div class="alert alert-info">
                        <p class="mb-0">Aquí se mostraría el detalle completo del sitio seleccionado (ID: @ViewBag.SitioId)</p>
                    </div>
                    <a asp-action="Index" class="btn btn-secondary mt-3">Regresar</a>
                </div>
            </div>
        </div>
    </div>
</div>
