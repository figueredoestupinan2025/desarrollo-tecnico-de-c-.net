@model IEnumerable<ReservasFondoXYZ.Data.Models.Sitio>

@{
    ViewData["Title"] = "Sistema de Reservas - FODUN";
}

<div class="mb-4">
    <ul class="nav nav-tabs mb-3" id="sitiosTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="sedes-tab" data-bs-toggle="tab" data-bs-target="#sedes" type="button" role="tab" aria-controls="sedes" aria-selected="true">Sedes Recreativas y Apartamentos</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="seleccion-tab" data-bs-toggle="tab" data-bs-target="#seleccion" type="button" role="tab" aria-controls="seleccion" aria-selected="false">Seleccione una Sede</button>
        </li>
    </ul>
    
    <div class="tab-content" id="sitiosTabContent">
        <div class="tab-pane fade show active" id="sedes" role="tabpanel" aria-labelledby="sedes-tab">
            <table class="table table-bordered bg-white mb-0">
                <tbody>
                    @{
                        var sitiosList = Model.ToList();
                        for (int i = 0; i < sitiosList.Count; i += 2)
                        {
                            <tr>
                                <td class="p-3" style="width: 50%;">
                                    <div class="d-flex">
                                        <div class="me-3">
                                            @* NOTA: Para producción, usar imágenes propias alojadas en wwwroot/images o CDN controlado *@
                                            <img src="https://picsum.photos/seed/@sitiosList[i].Id/100/100" class="sitio-imagen" alt="@sitiosList[i].Nombre" style="width: 100px; height: 100px;">
                                        </div>
                                        <div class="flex-grow-1">
                                            <h6 class="card-title mb-1 fw-bold text-danger">@sitiosList[i].Nombre</h6>
                                            <p class="mb-1"><small>Ubicación: @sitiosList[i].Ubicacion</small></p>
                                            <p class="mb-2"><small>@sitiosList[i].TipoSitio?.Nombre</small></p>
                                            <div class="d-flex gap-2">
                                                <a asp-controller="Reserva" asp-action="Disponibilidad" asp-route-sitioId="@sitiosList[i].Id" class="btn btn-danger btn-sm fw-bold" style="font-size: 0.8rem;">Consultar Disponibilidad</a>
                                                <a asp-controller="Home" asp-action="Ver" asp-route-id="@sitiosList[i].Id" class="btn btn-secondary btn-sm fw-bold" style="font-size: 0.8rem;">Ver</a>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                @if (i + 1 < sitiosList.Count)
                                {
                                    <td class="p-3" style="width: 50%;">
                                        <div class="d-flex">
                                            <div class="me-3">
                                                @* NOTA: Para producción, usar imágenes propias alojadas en wwwroot/images o CDN controlado *@
                                                <img src="https://picsum.photos/seed/@sitiosList[i+1].Id/100/100" class="sitio-imagen" alt="@sitiosList[i+1].Nombre" style="width: 100px; height: 100px;">
                                            </div>
                                            <div class="flex-grow-1">
                                                <h6 class="card-title mb-1 fw-bold text-danger">@sitiosList[i+1].Nombre</h6>
                                                <p class="mb-1"><small>Ubicación: @sitiosList[i+1].Ubicacion</small></p>
                                                <p class="mb-2"><small>@sitiosList[i+1].TipoSitio?.Nombre</small></p>
                                                <div class="d-flex gap-2">
                                                    <a asp-controller="Reserva" asp-action="Disponibilidad" asp-route-sitioId="@sitiosList[i+1].Id" class="btn btn-danger btn-sm fw-bold" style="font-size: 0.8rem;">Consultar Disponibilidad</a>
                                                    <a asp-controller="Home" asp-action="Ver" asp-route-id="@sitiosList[i+1].Id" class="btn btn-secondary btn-sm fw-bold" style="font-size: 0.8rem;">Ver</a>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        
        <div class="tab-pane fade" id="seleccion" role="tabpanel" aria-labelledby="seleccion-tab">
            <div class="alert alert-info">
                Seleccione una sede desde la pestaña "Sedes Recreativas y Apartamentos"
            </div>
        </div>
    </div>
</div>

<footer class="border-top footer text-muted mt-4 py-3 bg-white">
    <div class="container-fluid text-center">
        <p class="mb-0" style="font-size: 0.8rem;">FODUN. Todos los derechos reservados. Diseño: Visual Studio, Versión 1.0.1</p>
    </div>
</footer>
