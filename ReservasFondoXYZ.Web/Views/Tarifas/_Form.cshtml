@model ReservasFondoXYZ.Web.ViewModels.TarifaFormViewModel

<form asp-action="@ViewContext.RouteData.Values["action"]" method="post" class="card">
    <div class="card-body">
        <div asp-validation-summary="All" class="text-danger"></div>
        <input type="hidden" asp-for="Id" />

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="SitioId" class="form-label"></label>
                <select asp-for="SitioId" asp-items="ViewBag.SitioId" class="form-select"></select>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="AlojamientoId" class="form-label"></label>
                <select asp-for="AlojamientoId" asp-items="ViewBag.AlojamientoId" class="form-select">
                    <option value="">General del sitio</option>
                </select>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="TipoTemporadaId" class="form-label"></label>
                <select asp-for="TipoTemporadaId" asp-items="ViewBag.TipoTemporadaId" class="form-select"></select>
            </div>
        </div>

        <div class="row">
            <div class="col-md-3 mb-3">
                <label asp-for="NumeroPersonasMin" class="form-label"></label>
                <input asp-for="NumeroPersonasMin" class="form-control" />
            </div>
            <div class="col-md-3 mb-3">
                <label asp-for="NumeroPersonasMax" class="form-label"></label>
                <input asp-for="NumeroPersonasMax" class="form-control" />
            </div>
            <div class="col-md-3 mb-3">
                <label asp-for="NumeroHabitaciones" class="form-label"></label>
                <input asp-for="NumeroHabitaciones" class="form-control" />
            </div>
            <div class="col-md-3 mb-3">
                <label asp-for="PrecioBase" class="form-label"></label>
                <input asp-for="PrecioBase" class="form-control" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="PrecioPersonaAdicional" class="form-label"></label>
                <input asp-for="PrecioPersonaAdicional" class="form-control" />
            </div>
            <div class="col-md-4 mb-3 d-flex align-items-end">
                <div class="form-check">
                    <input asp-for="EsTarifaEspecial" class="form-check-input" />
                    <label asp-for="EsTarifaEspecial" class="form-check-label"></label>
                </div>
            </div>
            <div class="col-md-4 mb-3 d-flex align-items-end">
                <div class="form-check">
                    <input asp-for="Activo" class="form-check-input" />
                    <label asp-for="Activo" class="form-check-label"></label>
                </div>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Descripcion" class="form-label"></label>
            <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
        </div>

        <button type="submit" class="btn btn-success">Guardar</button>
        <a asp-action="Index" class="btn btn-secondary">Volver</a>
    </div>
</form>
