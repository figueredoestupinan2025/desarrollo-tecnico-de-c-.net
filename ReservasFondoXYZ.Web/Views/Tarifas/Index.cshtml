@model IEnumerable<ReservasFondoXYZ.Data.Models.Tarifa>

@{
    ViewData["Title"] = "Tarifas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Tarifas</h1>
    <a asp-action="Create" class="btn btn-primary">Nueva Tarifa</a>
</div>

<div class="table-responsive">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Sitio</th>
                <th>Alojamiento</th>
                <th>Temporada</th>
                <th>Personas</th>
                <th>Habitaciones</th>
                <th>Precio</th>
                <th>Activa</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Sitio?.Nombre</td>
                    <td>@(item.Alojamiento?.Nombre ?? "General")</td>
                    <td>@item.TipoTemporada?.Nombre</td>
                    <td>@item.NumeroPersonasMin - @item.NumeroPersonasMax</td>
                    <td>@item.NumeroHabitaciones</td>
                    <td>$@item.PrecioBase.ToString("N0")</td>
                    <td>@(item.Activo ? "Sí" : "No")</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Ver</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
