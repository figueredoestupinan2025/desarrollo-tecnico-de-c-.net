@{
    ViewData["Title"] = "Contraseña Restablecida";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h4 class="text-center">¡Contraseña Restablecida!</h4>
                </div>
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="bi bi-check-circle" style="font-size: 4rem; color: #28a745;"></i>
                    </div>
                    <p class="lead mb-4">
                        Tu contraseña ha sido restablecida exitosamente.
                    </p>
                    <p class="text-muted mb-4">
                        Ahora puedes iniciar sesión con tu nueva contraseña.
                    </p>
                    <div class="d-grid">
                        <a asp-action="Login" class="btn btn-primary" style="background-color: #8B0000; border-color: #8B0000;">
                            Iniciar Sesión
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
