@model ReservasFondoXYZ.Web.Controllers.LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesión - Reservas FODUN";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card login-card">
                <div class="card-header bg-fodun text-center py-4">
                    <div class="d-flex align-items-center justify-content-center">
                        <div class="fodun-logo me-3">
                            <div class="logo-circle d-flex align-items-center justify-content-center">
                                <span class="logo-text">FODUN</span>
                            </div>
                        </div>
                        <div class="header-title text-start">
                            <h2 class="text-white m-0 fw-bold">SISTEMA DE RESERVAS</h2>
                            <p class="text-white m-0">Sedes Recreativas y Apartamentos</p>
                        </div>
                    </div>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="ReturnUrl" />

                        <div class="mb-4">
                            <label asp-for="NroDocumento" class="form-label fw-bold">Nro Documento:</label>
                            <input asp-for="NroDocumento" class="form-control form-control-lg" placeholder="Ingrese su número de documento" autofocus>
                            <span asp-validation-for="NroDocumento" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Clave" class="form-label fw-bold">Clave:</label>
                            <input asp-for="Clave" class="form-control form-control-lg" placeholder="Ingrese su clave">
                            <span asp-validation-for="Clave" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input">
                                <label asp-for="RememberMe" class="form-check-label">Recordarme</label>
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-danger btn-lg fw-bold">Ingresar</button>
                        </div>
                    </form>

                    <div class="mt-4 text-center">
                        <p class="mb-0">¿No tienes cuenta? <a asp-action="Register" class="text-danger fw-bold">Registrarse</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="text-center mt-5 text-muted">
    <p class="mb-0">Reservas - FODUN - Se recomienda utilizar Internet Explorer 9.0, Chrome, Firefox en una resolución de 1024 x 768 o superior - Derechos Reservados © 2026</p>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
