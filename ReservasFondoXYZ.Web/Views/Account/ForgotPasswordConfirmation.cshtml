@{
    ViewData["Title"] = "Enlace Enviado";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h4 class="text-center">¡Enlace Enviado!</h4>
                </div>
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="bi bi-check-circle" style="font-size: 4rem; color: #28a745;"></i>
                    </div>
                    <p class="lead mb-4">
                        Hemos enviado un enlace de restablecimiento de contraseña a tu correo electrónico.
                    </p>
                    <p class="text-muted mb-4">
                        Por favor revisa tu bandeja de entrada y sigue las instrucciones. Si no lo encuentras, revisa la carpeta de spam.
                    </p>
                    <div class="d-grid">
                        <a asp-action="Login" class="btn btn-primary" style="background-color: #8B0000; border-color: #8B0000;">
                            Volver al Inicio de Sesión
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
