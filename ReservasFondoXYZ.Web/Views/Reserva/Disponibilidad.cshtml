@model ReservasFondoXYZ.Web.ViewModels.DisponibilidadViewModel

@{
    ViewData["Title"] = "Consulta de Disponibilidad";
    var habitaciones = ViewBag.Habitaciones as IEnumerable<ReservasFondoXYZ.Data.Dtos.HabitacionDisponibleDto>;
}

<h1 class="mb-4">Consulta de Disponibilidad</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-warning">@TempData["Error"]</div>
}

<div class="card mb-4">
    <div class="card-body">
        <form method="post" class="row g-3" asp-action="Disponibilidad">
            <div asp-validation-summary="All" class="text-danger col-12"></div>

            <div class="col-md-3">
                <label asp-for="FechaInicio" class="form-label">Fecha de Inicio</label>
                <input asp-for="FechaInicio" type="date" class="form-control" required>
                <span asp-validation-for="FechaInicio" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="FechaFin" class="form-label">Fecha de Fin</label>
                <input asp-for="FechaFin" type="date" class="form-control" required>
                <span asp-validation-for="FechaFin" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label asp-for="NumeroPersonas" class="form-label">Número de Personas</label>
                <input asp-for="NumeroPersonas" type="number" class="form-control" min="1" max="20" required>
                <span asp-validation-for="NumeroPersonas" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="SitioId" class="form-label">Sitio (Opcional)</label>
                <select asp-for="SitioId" class="form-select">
                    <option value="">Todos los sitios</option>
                    @foreach (var sitio in ViewBag.Sitios)
                    {
                        <option value="@sitio.Id">@sitio.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Consultar</button>
            </div>
        </form>
    </div>
</div>

@if (habitaciones != null && habitaciones.Any())
{
    <h2 class="mb-3">Resultados de Disponibilidad</h2>

    @foreach (var grupo in habitaciones.GroupBy(h => new { h.SitioId, h.SitioNombre, h.AlojamientoId, h.AlojamientoNombre, h.TipoSitio }))
    {
        <form method="get" asp-action="Crear" class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <strong>@grupo.Key.SitioNombre</strong>
                    <span class="text-muted">- @grupo.Key.AlojamientoNombre</span>
                </div>
                <span class="badge bg-secondary">@grupo.Key.TipoSitio</span>
            </div>
            <div class="card-body">
                <input type="hidden" name="sitioId" value="@grupo.Key.SitioId" />
                <input type="hidden" name="alojamientoId" value="@grupo.Key.AlojamientoId" />
                <input type="hidden" name="fechaInicio" value="@ViewBag.FechaInicio?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="fechaFin" value="@ViewBag.FechaFin?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="numeroPersonas" value="@ViewBag.NumeroPersonas" />

                <div class="row">
                    @foreach (var habitacion in grupo)
                    {
                        <div class="col-md-4 mb-2">
                            <div class="form-check border rounded p-3 h-100">
                                <input class="form-check-input ms-0 me-2" type="checkbox" name="habitacionesIds" value="@habitacion.Id" id="habitacion_@habitacion.Id" />
                                <label class="form-check-label ps-4" for="habitacion_@habitacion.Id">
                                    <strong>Habitación @habitacion.Numero</strong><br />
                                    <span>Capacidad: @habitacion.CapacidadMaxima personas</span>
                                    @if (!string.IsNullOrEmpty(habitacion.Descripcion))
                                    {
                                        <br><small class="text-muted">@habitacion.Descripcion</small>
                                    }
                                </label>
                            </div>
                        </div>
                    }
                </div>

                <button type="submit" class="btn btn-success mt-2">Reservar habitaciones seleccionadas</button>
            </div>
        </form>
    }
}
else if (ViewBag.FechaInicio != null)
{
    <div class="alert alert-info">No hay habitaciones disponibles para las fechas y condiciones seleccionadas.</div>
}
