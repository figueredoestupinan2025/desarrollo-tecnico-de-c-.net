@model ReservasFondoXYZ.Data.Models.Reserva

@{
    ViewData["Title"] = "Confirmación de Reserva";
    var sitio = ViewBag.Sitio;
    var alojamiento = ViewBag.Alojamiento;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header text-center" style="background-color: #28a745; color: white;">
                    <h3><i class="bi bi-check-circle-fill"></i> ¡Reserva Confirmada!</h3>
                </div>
                <div class="card-body text-center">
                    <div class="mb-4">
                        <h5 class="text-success">Número de Reserva: #@Model.Id</h5>
                        <p class="text-muted">Gracias por tu reserva. Hemos recibido tu pago exitosamente.</p>
                    </div>

                    <div class="card mb-4">
                        <div class="card-header">
                            <h6>Detalles de la Reserva</h6>
                        </div>
                        <div class="card-body text-start">
                            <dl class="row">
                                <dt class="col-sm-4">Sitio</dt>
                                <dd class="col-sm-8">@sitio?.Nombre</dd>

                                <dt class="col-sm-4">Alojamiento</dt>
                                <dd class="col-sm-8">@alojamiento?.Nombre</dd>

                                <dt class="col-sm-4">Fecha de Inicio</dt>
                                <dd class="col-sm-8">@Model.FechaInicio.ToString("dd/MM/yyyy")</dd>

                                <dt class="col-sm-4">Fecha de Fin</dt>
                                <dd class="col-sm-8">@Model.FechaFin.ToString("dd/MM/yyyy")</dd>

                                <dt class="col-sm-4">Número de Personas</dt>
                                <dd class="col-sm-8">@Model.NumeroPersonas</dd>

                                <dt class="col-sm-4">Número de Habitaciones</dt>
                                <dd class="col-sm-8">@Model.NumeroHabitaciones</dd>

                                <dt class="col-sm-4">Tarifa Total</dt>
                                <dd class="col-sm-8"><strong class="text-success">$@Model.TarifaTotal.ToString("N0")</strong></dd>

                                <dt class="col-sm-4">Estado</dt>
                                <dd class="col-sm-8">
                                    <span class="badge bg-success">Pagada y Confirmada</span>
                                </dd>

                                <dt class="col-sm-4">Fecha de Reserva</dt>
                                <dd class="col-sm-8">@Model.FechaReserva.ToString("dd/MM/yyyy HH:mm")</dd>
                            </dl>
                        </div>
                    </div>

                    <div class="d-flex justify-content-center gap-3">
                        <a asp-action="MisReservas" class="btn btn-primary" style="background-color: #8B0000; border-color: #8B0000;">
                            <i class="bi bi-list-check"></i> Ver Mis Reservas
                        </a>
                        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">
                            <i class="bi bi-house-door"></i> Ir al Inicio
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>