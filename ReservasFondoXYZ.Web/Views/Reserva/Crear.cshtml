@model ReservasFondoXYZ.Data.Models.Reserva

@{
    ViewData["Title"] = "Crear Reserva";
    var sitio = ViewBag.Sitio;
    var alojamiento = ViewBag.Alojamiento;
}

<h1 class="mb-4">Crear Reserva</h1>

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header">
                <h5>@sitio?.Nombre</h5>
            </div>
            <div class="card-body">
                <h6>@alojamiento?.Nombre</h6>
                <p>
                    <strong>Fechas:</strong> @Model.FechaInicio.ToString("dd/MM/yyyy") - @Model.FechaFin.ToString("dd/MM/yyyy")<br>
                    <strong>Número de Personas:</strong> @Model.NumeroPersonas<br>
                    <strong>Número de Habitaciones:</strong> @Model.NumeroHabitaciones
                </p>
                <div class="alert alert-info">
                    <strong>Tarifa Total Estimada:</strong> $@Model.TarifaTotal.ToString("N0")
                </div>
            </div>
        </div>

        <form method="post" asp-action="Crear">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            
            <input type="hidden" asp-for="SitioId" />
            <input type="hidden" asp-for="AlojamientoId" />
            <input type="hidden" asp-for="FechaInicio" />
            <input type="hidden" asp-for="FechaFin" />
            <input type="hidden" asp-for="NumeroPersonas" />
            <input type="hidden" asp-for="NumeroHabitaciones" />
            <input type="hidden" asp-for="TarifaTotal" />

            <div class="mb-3">
                <label asp-for="Observaciones" class="form-label">Observaciones (Opcional)</label>
                <textarea asp-for="Observaciones" class="form-control" rows="3"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Confirmar Reserva</button>
                <a asp-action="Disponibilidad" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
