@model ReservasFondoXYZ.Data.Models.Reserva

@{
    ViewData["Title"] = "Detalles de Reserva";
}

<h1 class="mb-4">Detalles de Reserva #@Model.Id</h1>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Sitio</dt>
            <dd class="col-sm-9">@Model.Sitio?.Nombre</dd>

            <dt class="col-sm-3">Alojamiento</dt>
            <dd class="col-sm-9">@Model.Alojamiento?.Nombre</dd>

            <dt class="col-sm-3">Fecha de Inicio</dt>
            <dd class="col-sm-9">@Model.FechaInicio.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Fecha de Fin</dt>
            <dd class="col-sm-9">@Model.FechaFin.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Número de Personas</dt>
            <dd class="col-sm-9">@Model.NumeroPersonas</dd>

            <dt class="col-sm-3">Número de Habitaciones</dt>
            <dd class="col-sm-9">@Model.NumeroHabitaciones</dd>

            <dt class="col-sm-3">Habitaciones</dt>
            <dd class="col-sm-9">
                @if (Model.ReservaHabitaciones.Any())
                {
                    @string.Join(", ", Model.ReservaHabitaciones.Select(rh => rh.Habitacion?.Numero))
                }
                else
                {
                    <span>No registradas</span>
                }
            </dd>

            <dt class="col-sm-3">Tarifa Total</dt>
            <dd class="col-sm-9">$@Model.TarifaTotal.ToString("N0")</dd>

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">@Model.EstadoReserva?.Nombre</dd>

            <dt class="col-sm-3">Fecha de Reserva</dt>
            <dd class="col-sm-9">@Model.FechaReserva.ToString("dd/MM/yyyy HH:mm")</dd>

            @if (!string.IsNullOrEmpty(Model.Observaciones))
            {
                <dt class="col-sm-3">Observaciones</dt>
                <dd class="col-sm-9">@Model.Observaciones</dd>
            }
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="MisReservas" class="btn btn-secondary">Volver a Mis Reservas</a>
</div>
